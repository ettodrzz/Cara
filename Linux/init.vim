" SHOW LINE NUMBERS
set number

" SYNTAX HIGHLIGHTING ON
syntax on

" TYPE FILE DETECTION
filetype on

" TABS
" Use space characters
set expandtab
" Size
set shiftwidth=4
set tabstop=4
" Auto indentation
set smartindent

" BACKSPACE BEHAVIOUR
set backspace=indent,eol,start

" REMOVE SWAP AND BACKUP FILES FROM WORKING DIRECTORY
set directory=/tmp
set backupdir=/tmp

" DISABLE ERROR BELLS
set belloff=all

" DISABLE COMPATIBILITY WITH VI
set nocompatible
